{
  "manifest_version": 3,
  "name": "AlgoVision",
  "version": "1.1.0",
  "description": "Analyze LeetCode problems and prepare their inputs for AlgoVision visualization.",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://leetcode.com/*"
  ],

  "action": {
    "default_title": "Open AlgoVision",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "algovision-extension@example.com",
      "strict_min_version": "109.0"
    }
  }
}