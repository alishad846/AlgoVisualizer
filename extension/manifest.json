{
  "manifest_version": 3,
  "name": "AlgoVision AI",
  "version": "3.0.0",
  "description": "AI-Powered Algorithm Detection and Visualization Assistant",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.leetcode.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.leetcode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}