# Copy this file to .env and fill values
# Example DATABASE_URL format:
# postgres://<user>:<password>@<host>:<port>/<database>

# Example:
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/algo_db

# If you're using separate env vars (optional):
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=algo_db
